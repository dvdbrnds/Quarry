# ─── Required ───────────────────────────────────────────────
HOUNDDOG_DATABASE_URL=postgresql+asyncpg://hounddog:CHANGE_ME@db:5432/hounddog
HOUNDDOG_SECRET_KEY=generate-a-real-secret-key
HOUNDDOG_DEBUG=false

# PostgreSQL (used by docker-compose)
POSTGRES_USER=hounddog
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hounddog

# CORS – comma-separated or JSON array of allowed origins
HOUNDDOG_CORS_ORIGINS=["https://hounddog.yourdomain.edu"]

# ─── Okta SSO (Dashboard auth) ─────────────────────────────
HOUNDDOG_OKTA_DOMAIN=
HOUNDDOG_OKTA_CLIENT_ID=
HOUNDDOG_OKTA_CLIENT_SECRET=
HOUNDDOG_OKTA_AUDIENCE=

# ─── Stripe (Student payments) ─────────────────────────────
HOUNDDOG_STRIPE_SECRET_KEY=
HOUNDDOG_STRIPE_WEBHOOK_SECRET=
HOUNDDOG_STRIPE_PUBLISHABLE_KEY=
