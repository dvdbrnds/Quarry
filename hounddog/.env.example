# ─── Required ───────────────────────────────────────────────
QUARRY_DATABASE_URL=postgresql+asyncpg://quarry:CHANGE_ME@db:5432/quarry
QUARRY_SECRET_KEY=generate-a-real-secret-key
QUARRY_DEBUG=false

# ─── Instance Identity (for QR device pairing) ──────────────
QUARRY_PUBLIC_URL=https://quarry.yourdomain.edu
QUARRY_SCHOOL_NAME=Your University

# PostgreSQL (used by docker-compose)
POSTGRES_USER=quarry
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=quarry

# CORS – comma-separated or JSON array of allowed origins
QUARRY_CORS_ORIGINS=["https://quarry.yourdomain.edu"]

# ─── Google Maps ──────────────────────────────────────────
QUARRY_GOOGLE_MAPS_API_KEY=

# ─── Okta SSO (Dashboard auth) ─────────────────────────────
QUARRY_OKTA_DOMAIN=
QUARRY_OKTA_CLIENT_ID=
QUARRY_OKTA_CLIENT_SECRET=
QUARRY_OKTA_AUDIENCE=

# ─── Stripe (Student payments) ─────────────────────────────
QUARRY_STRIPE_SECRET_KEY=
QUARRY_STRIPE_WEBHOOK_SECRET=
QUARRY_STRIPE_PUBLISHABLE_KEY=

# ─── APNs (Push to BirdDog devices) ──────────────────────────
QUARRY_APNS_KEY_PATH=
QUARRY_APNS_KEY_ID=
QUARRY_APNS_TEAM_ID=
QUARRY_APNS_BUNDLE_ID=edu.moravian.birddog
QUARRY_APNS_USE_SANDBOX=true
